# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# ── AI провайдеры (нужен хотя бы один) ──
# Бот перебирает по порядку: Gemini → Groq → Cerebras → OpenRouter
# Чем больше ключей — тем надёжнее (если один упал, берёт следующий)

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (быстрый, llama-3.3-70b) — https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras (1M токенов/день) — https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# OpenRouter (агрегатор, 24+ бесплатных моделей) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
